<jasperReport name="laporanPendapatan" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f6b010f1-ce94-4cc7-b170-24337cad0fe8">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SI_BAMBU"/>
	<parameter name="tglDari" class="java.util.Date"/>
	<parameter name="tglSampai" class="java.util.Date"/>
	<query language="SQL"><![CDATA[SELECT idTransaksi,
       namaPembeli,
       jmlBarang,
       CAST(total AS DECIMAL(15,2)) AS total,
       tglTransaksi
FROM transaksi 
WHERE DATE(tglTransaksi) BETWEEN DATE($P{tglDari}) AND DATE($P{tglSampai})
ORDER BY tglTransaksi ASC]]></query>
	<field name="idTransaksi" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.field.name" value="idTransaksi"/>
		<property name="com.jaspersoft.studio.field.label" value="idTransaksi"/>
