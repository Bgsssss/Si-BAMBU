	</field>
	<field name="namaPembeli" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="namaPembeli"/>
		<property name="com.jaspersoft.studio.field.label" value="namaPembeli"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="transaksi"/>
	</field>
	<field name="jmlBarang" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="jmlBarang"/>
		<property name="com.jaspersoft.studio.field.label" value="jmlBarang"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="transaksi"/>
	</field>
	<field name="total" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="total"/>
		<property name="com.jaspersoft.studio.field.label" value="total"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="transaksi"/>
	</field>
	<field name="tglTransaksi" class="java.sql.Date">
		<property name="com.jaspersoft.studio.field.name" value="tglTransaksi"/>
		<property name="com.jaspersoft.studio.field.label" value="tglTransaksi"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="transaksi"/>
	</field>
	<variable name="grandTotal" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{total}]]></expression>
	</variable>
